# dbt-snowplow-web: incremental/snowplow_web_users_lasts
# Source: test-dbt-snowplow-web/queries/incremental/users/scratch/snowplow_web_users_lasts.sql

include ../../../fixtures/snowplow/setup.slt

statement ok
select
  a.domain_userid,
  a.last_page_title,
  a.last_page_url,
  a.last_page_urlscheme,
  a.last_page_urlhost,
  a.last_page_urlpath,
  a.last_page_urlquery,
  a.last_page_urlfragment,
  a.last_geo_country,
  a.last_geo_country_name,
  a.last_geo_continent,
  a.last_geo_city,
  a.last_geo_region_name,
  a.last_br_lang,
  a.last_br_lang_name
from embucket.public_snowplow_manifest_scratch.snowplow_web_users_sessions_this_run a
inner join embucket.public_snowplow_manifest_scratch.snowplow_web_users_aggs b
on a.domain_sessionid = b.last_domain_sessionid

# Verification (vs Snowflake on the same 200-row fixture).
# TODO(snowflake-verify): replace TODO placeholders with the row(s)
# returned by running this query against the dbt-snowplow-web tables
# in Snowflake. Numeric cells should match exactly; text cells should
# match verbatim (UUIDs, hostnames, etc.).
query TTT
select domain_userid, last_page_urlhost, last_geo_country from embucket.public_snowplow_manifest_scratch.snowplow_web_users_lasts order by domain_userid limit 10
