# dbt-snowplow-web: incremental/snowplow_web_base_events_this_run
# Source: test-dbt-snowplow-web/queries/incremental/base/scratch/snowflake/snowplow_web_base_events_this_run.sql

include ../../../fixtures/snowplow/setup.slt

statement ok
with base_query as (
        with identified_events AS (
            select
                COALESCE(
                        e.domain_sessionid,NULL
                    ) as session_identifier,
                e.*
            from embucket.public_snowplow_manifest.events e
        )
        select
            a.*,
            b.user_identifier -- take user_identifier from manifest. This ensures only 1 domain_userid per session.
        from identified_events as a
        inner join embucket.public_snowplow_manifest_scratch.snowplow_web_base_sessions_this_run as b
        on a.session_identifier = b.session_identifier
        where a.collector_tstamp <= 
    dateadd(
        day,
        3,
        b.start_tstamp
        )
        and a.dvce_sent_tstamp <= 
    dateadd(
        day,
        3,
        a.dvce_created_tstamp
        )
        and a.collector_tstamp >= 
        cast('2026-04-29 21:04:22.898084' as timestamp)
        and a.collector_tstamp <= 
        cast('2026-04-29 23:51:02.898084' as timestamp)
        and a.collector_tstamp >= b.start_tstamp -- deal with late loading events
        and true
        qualify row_number() over (partition by a.event_id order by a.collector_tstamp, a.dvce_created_tstamp) = 1
)
select
  a.contexts_com_snowplowanalytics_snowplow_web_page_1[0]:id::varchar as page_view_id,
  a.session_identifier as domain_sessionid,
  a.domain_sessionid as original_domain_sessionid,
  a.user_identifier as domain_userid,
  a.domain_userid as original_domain_userid,
  a.* exclude(contexts_com_snowplowanalytics_snowplow_web_page_1, domain_sessionid, domain_userid)
from base_query a

# Verification (vs Snowflake on the same 200-row fixture).
# TODO(snowflake-verify): replace TODO placeholders with the row(s)
# returned by running this query against the dbt-snowplow-web tables
# in Snowflake. Numeric cells should match exactly; text cells should
# match verbatim (UUIDs, hostnames, etc.).
query IIII
select count(*), count(distinct event_id), count(distinct domain_sessionid), count(distinct domain_userid) from embucket.public_snowplow_manifest_scratch.snowplow_web_base_events_this_run
