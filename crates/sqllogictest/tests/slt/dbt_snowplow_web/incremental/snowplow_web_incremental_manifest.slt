# dbt-snowplow-web: incremental/snowplow_web_incremental_manifest
# Source: test-dbt-snowplow-web/queries/incremental/base/manifest/snowplow_web_incremental_manifest.sql

include ../../../fixtures/snowplow/setup.slt

statement ok
        with prep as (
        select
            cast(null as 
    TEXT
) model,
            cast('1970-01-01' as timestamp) as last_success
        )
        select *
        from prep
        where false

# In real Snowflake this manifest grows by one row per successful model
# run (snowplow_web_incremental_manifest is populated by the package's
# post-hook). Our setup only executes the model CREATE/MERGE statements,
# not the post-hooks, so the table stays empty after 2 simulated runs.
query I
select count(*) from embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_incremental_manifest
----
0
