# dbt-snowplow-web: full_refresh/snowplow_web_users_aggs
# Source: test-dbt-snowplow-web/queries/full-refresh/users/scratch/snowplow_web_users_aggs.sql

include ../../../fixtures/snowplow/setup.slt

statement ok
select
  domain_userid,
  -- time
  user_start_tstamp as start_tstamp,
  user_end_tstamp as end_tstamp,
  -- first/last session. Max to resolve edge case with multiple sessions with the same start/end tstamp
  max(case when start_tstamp = user_start_tstamp then domain_sessionid end) as first_domain_sessionid,
  max(case when end_tstamp = user_end_tstamp then domain_sessionid end) as last_domain_sessionid,
  -- engagement
  sum(page_views) as page_views,
  count(distinct domain_sessionid) as sessions,
  sum(engaged_time_in_s) as engaged_time_in_s
from embucket.public_snowplow_manifest_scratch.snowplow_web_users_sessions_this_run
group by 1,2,3

# Verification (vs Snowflake on the same 200-row fixture).
# TODO(snowflake-verify): replace TODO placeholders with the row(s)
# returned by running this query against the dbt-snowplow-web tables
# in Snowflake. Numeric cells should match exactly; text cells should
# match verbatim (UUIDs, hostnames, etc.).
query TIII
select domain_userid, page_views, sessions, engaged_time_in_s from embucket.public_snowplow_manifest_scratch.snowplow_web_users_aggs order by domain_userid limit 10
