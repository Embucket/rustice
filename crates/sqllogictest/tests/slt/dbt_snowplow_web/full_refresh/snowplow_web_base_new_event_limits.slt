statement ok
      select 
        cast('2026-04-01' as timestamp)
     as lower_limit,
              least(
    dateadd(
        day,
        60,
        cast('2026-04-01' as timestamp)
        )
,
    convert_timezone('UTC', convert_timezone('UTC', current_timestamp()))::timestamp
) as upper_limit
