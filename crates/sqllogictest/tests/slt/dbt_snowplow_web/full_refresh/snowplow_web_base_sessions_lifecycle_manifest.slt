# dbt-snowplow-web: full_refresh/snowplow_web_base_sessions_lifecycle_manifest
# Source: test-dbt-snowplow-web/queries/full-refresh/base/manifest/snowplow_web_base_sessions_lifecycle_manifest.sql

include ../../../fixtures/snowplow/setup.full_refresh.slt

statement ok
        with new_events_session_ids_init as (
            select
                COALESCE(
                    e.domain_sessionid,NULL
                ) as session_identifier,
                max(
                    COALESCE(
                        e.domain_userid,NULL
                    )
                ) as user_identifier, -- Edge case 1: Arbitary selection to avoid window function like first_value.
                min(collector_tstamp) as start_tstamp,
                max(collector_tstamp) as end_tstamp
            from embucket.public_snowplow_manifest.events e
            where
                dvce_sent_tstamp <= 
    dateadd(
        day,
        3,
        dvce_created_tstamp
        )
 -- don't process data that's too late
                and collector_tstamp >= 
        cast('9999-01-01 00:00:00' as timestamp)
                and collector_tstamp <= 
        cast('9999-01-01 00:00:00' as timestamp)
                and true
                and True --don't reprocess sessions that have already been processed.
            group by 1
        ), new_events_session_ids as (
            select *
            from new_events_session_ids_init e
                where session_identifier is not null
                and not exists (select 1 from embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_base_quarantined_sessions as a where a.session_identifier = e.session_identifier) -- don't continue processing v.long sessions
        )
        , session_lifecycle as (
        select * from new_events_session_ids
        )
        select
        sl.session_identifier,
        sl.user_identifier,
        sl.start_tstamp,
        least(
    dateadd(
        day,
        3,
        sl.start_tstamp
        )
, sl.end_tstamp) as end_tstamp -- limit session length to max_session_days
        from session_lifecycle sl

# Verification (vs Snowflake on the same 200-row fixture).
# TODO(snowflake-verify): replace TODO placeholders with the row(s)
# returned by running this query against the dbt-snowplow-web tables
# in Snowflake. Numeric cells should match exactly; text cells should
# match verbatim (UUIDs, hostnames, etc.).
query TT
select session_identifier, user_identifier from embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_base_sessions_lifecycle_manifest order by session_identifier limit 10
