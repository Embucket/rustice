# snowplow_web_users
# Full-refresh CTAS (creates table with correct schema)
#   ← full-refresh/users/snowplow_web_users.sql
statement ok
CREATE TABLE embucket.public_snowplow_manifest_derived.snowplow_web_users AS
select *
from embucket.public_snowplow_manifest_scratch.snowplow_web_users_this_run
where True --returns false if run doesn't contain new events.
;

# Incremental upsert phase 1 of 2: build the dbt temp source table.
#   ← incremental/users/snowplow_web_users.sql
statement ok
CREATE TABLE embucket.public_snowplow_manifest_derived.snowplow_web_users__dbt_tmp AS
select *
from embucket.public_snowplow_manifest_scratch.snowplow_web_users_this_run
where True --returns false if run doesn't contain new events.
;

