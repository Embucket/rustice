# ---------------------------------------------------------------------------
# DAG materialisation: for each model, run its full-refresh SQL as
# CREATE TABLE AS to lay down the schema. Then either INSERT INTO (for
# `+materialized: table` models) or materialise a `<model>__dbt_tmp`
# scratch table from the incremental SELECT and run the verbatim MERGE
# extracted from dbt-snowflake target/run/.../<model>.sql (for the 4
# canonical `+materialized: incremental` derived models). Mirrors how
# dbt-snowplow-web boots a cold warehouse and then runs an incremental
# cycle. Generated by dev/regen-snowplow-setup.sh.
# ---------------------------------------------------------------------------

# snowplow_web_incremental_manifest
# Full-refresh CTAS (creates table with correct schema)
#   ← full-refresh/base/manifest/snowplow_web_incremental_manifest.sql
statement ok
CREATE TABLE embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_incremental_manifest AS
        with prep as (
        select
            cast(null as 
    TEXT
) model,
            cast('1970-01-01' as timestamp) as last_success
        )
        select *
        from prep
        where false
;

# Incremental load (populates with real-timestamp data)
#   ← incremental/base/manifest/snowplow_web_incremental_manifest.sql
statement ok
INSERT INTO embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_incremental_manifest
        with prep as (
        select
            cast(null as 
    TEXT
) model,
            cast('1970-01-01' as timestamp) as last_success
        )
        select *
        from prep
        where false
;

