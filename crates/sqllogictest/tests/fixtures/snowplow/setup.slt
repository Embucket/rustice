control substitution on

# Note: with substitution enabled, the `subst` crate parses backslash
# escapes. The literal `\t` we want the SQL engine to see as
# `FIELD_DELIMITER` must be written as `\\t` here — `subst` collapses
# `\\` → `\`, yielding `'\t'` post-substitution.
statement ok
COPY INTO embucket.public_snowplow_manifest_scratch.enriched_raw
FROM 'file://${CRATE_ROOT}/tests/fixtures/snowplow/events.csv'
FILE_FORMAT = ( TYPE = 'CSV' FIELD_DELIMITER = '\\t' SKIP_HEADER = 0 );

control substitution off

statement ok
CREATE TABLE embucket.public_snowplow_manifest.events AS
SELECT
    NULLIF(app_id, '')                                          AS app_id,
    NULLIF(platform, '')                                        AS platform,
    CAST(NULLIF(etl_tstamp, '')               AS TIMESTAMP)     AS etl_tstamp,
    CAST(NULLIF(collector_tstamp, '')         AS TIMESTAMP)     AS collector_tstamp,
    CAST(NULLIF(dvce_created_tstamp, '')      AS TIMESTAMP)     AS dvce_created_tstamp,
    NULLIF(event, '')                                           AS event,
    NULLIF(event_id, '')                                        AS event_id,
    CAST(NULLIF(txn_id, '')                   AS INT)           AS txn_id,
    NULLIF(name_tracker, '')                                    AS name_tracker,
    NULLIF(v_tracker, '')                                       AS v_tracker,
    NULLIF(v_collector, '')                                     AS v_collector,
    NULLIF(v_etl, '')                                           AS v_etl,
    NULLIF(user_id, '')                                         AS user_id,
    NULLIF(user_ipaddress, '')                                  AS user_ipaddress,
    NULLIF(user_fingerprint, '')                                AS user_fingerprint,
    NULLIF(domain_userid, '')                                   AS domain_userid,
    CAST(NULLIF(domain_sessionidx, '')        AS INT)           AS domain_sessionidx,
    NULLIF(network_userid, '')                                  AS network_userid,
    NULLIF(geo_country, '')                                     AS geo_country,
    NULLIF(geo_region, '')                                      AS geo_region,
    NULLIF(geo_city, '')                                        AS geo_city,
    NULLIF(geo_zipcode, '')                                     AS geo_zipcode,
    CAST(NULLIF(geo_latitude, '')             AS DOUBLE)        AS geo_latitude,
    CAST(NULLIF(geo_longitude, '')            AS DOUBLE)        AS geo_longitude,
    NULLIF(geo_region_name, '')                                 AS geo_region_name,
    NULLIF(ip_isp, '')                                          AS ip_isp,
    NULLIF(ip_organization, '')                                 AS ip_organization,
    NULLIF(ip_domain, '')                                       AS ip_domain,
    NULLIF(ip_netspeed, '')                                     AS ip_netspeed,
    NULLIF(page_url, '')                                        AS page_url,
    NULLIF(page_title, '')                                      AS page_title,
    NULLIF(page_referrer, '')                                   AS page_referrer,
    NULLIF(page_urlscheme, '')                                  AS page_urlscheme,
    NULLIF(page_urlhost, '')                                    AS page_urlhost,
    CAST(NULLIF(page_urlport, '')             AS INT)           AS page_urlport,
    NULLIF(page_urlpath, '')                                    AS page_urlpath,
    NULLIF(page_urlquery, '')                                   AS page_urlquery,
    NULLIF(page_urlfragment, '')                                AS page_urlfragment,
    NULLIF(refr_urlscheme, '')                                  AS refr_urlscheme,
    NULLIF(refr_urlhost, '')                                    AS refr_urlhost,
    CAST(NULLIF(refr_urlport, '')             AS INT)           AS refr_urlport,
    NULLIF(refr_urlpath, '')                                    AS refr_urlpath,
    NULLIF(refr_urlquery, '')                                   AS refr_urlquery,
    NULLIF(refr_urlfragment, '')                                AS refr_urlfragment,
    NULLIF(refr_medium, '')                                     AS refr_medium,
    NULLIF(refr_source, '')                                     AS refr_source,
    NULLIF(refr_term, '')                                       AS refr_term,
    NULLIF(mkt_medium, '')                                      AS mkt_medium,
    NULLIF(mkt_source, '')                                      AS mkt_source,
    NULLIF(mkt_term, '')                                        AS mkt_term,
    NULLIF(mkt_content, '')                                     AS mkt_content,
    NULLIF(mkt_campaign, '')                                    AS mkt_campaign,
    NULLIF(contexts, '')                                        AS contexts,
    -- Per-schema split-out for the web_page context (mimics RDB Loader output).
    -- Snowplow web_page.data only carries `id`, so capturing the uuid via
    -- REGEXP_SUBSTR's `'e'` (extract group) parameter with group_num=1 is
    -- reliable for the generator's canonical SDK JSON. Stored as a JSON string
    -- `[{"id":"<uuid>"}]`; rustice's ARRAY is internally a Utf8 column holding
    -- JSON, so dbt-snowplow-web's `[0]:id::varchar` access compiles into
    -- `variant_element(...)` against this string.
    CASE
      WHEN REGEXP_SUBSTR(contexts, '"iglu:com\\.snowplowanalytics\\.snowplow/web_page/jsonschema/1-0-0","data":\\{"id":"([^"]+)"', 1, 1, 'e', 1) IS NOT NULL THEN
        '[{"id":"' || REGEXP_SUBSTR(contexts, '"iglu:com\\.snowplowanalytics\\.snowplow/web_page/jsonschema/1-0-0","data":\\{"id":"([^"]+)"', 1, 1, 'e', 1) || '"}]'
      ELSE NULL
    END                                                         AS contexts_com_snowplowanalytics_snowplow_web_page_1,
    NULLIF(se_category, '')                                     AS se_category,
    NULLIF(se_action, '')                                       AS se_action,
    NULLIF(se_label, '')                                        AS se_label,
    NULLIF(se_property, '')                                     AS se_property,
    CAST(NULLIF(se_value, '')                 AS DOUBLE)        AS se_value,
    NULLIF(unstruct_event, '')                                  AS unstruct_event,
    NULLIF(tr_orderid, '')                                      AS tr_orderid,
    NULLIF(tr_affiliation, '')                                  AS tr_affiliation,
    CAST(NULLIF(tr_total, '')                 AS DOUBLE)        AS tr_total,
    CAST(NULLIF(tr_tax, '')                   AS DOUBLE)        AS tr_tax,
    CAST(NULLIF(tr_shipping, '')              AS DOUBLE)        AS tr_shipping,
    NULLIF(tr_city, '')                                         AS tr_city,
    NULLIF(tr_state, '')                                        AS tr_state,
    NULLIF(tr_country, '')                                      AS tr_country,
    NULLIF(ti_orderid, '')                                      AS ti_orderid,
    NULLIF(ti_sku, '')                                          AS ti_sku,
    NULLIF(ti_name, '')                                         AS ti_name,
    NULLIF(ti_category, '')                                     AS ti_category,
    CAST(NULLIF(ti_price, '')                 AS DOUBLE)        AS ti_price,
    CAST(NULLIF(ti_quantity, '')              AS INT)           AS ti_quantity,
    CAST(NULLIF(pp_xoffset_min, '')           AS INT)           AS pp_xoffset_min,
    CAST(NULLIF(pp_xoffset_max, '')           AS INT)           AS pp_xoffset_max,
    CAST(NULLIF(pp_yoffset_min, '')           AS INT)           AS pp_yoffset_min,
    CAST(NULLIF(pp_yoffset_max, '')           AS INT)           AS pp_yoffset_max,
    NULLIF(useragent, '')                                       AS useragent,
    NULLIF(br_name, '')                                         AS br_name,
    NULLIF(br_family, '')                                       AS br_family,
    NULLIF(br_version, '')                                      AS br_version,
    NULLIF(br_type, '')                                         AS br_type,
    NULLIF(br_renderengine, '')                                 AS br_renderengine,
    NULLIF(br_lang, '')                                         AS br_lang,
    CAST(NULLIF(br_features_pdf, '')          AS BOOLEAN)       AS br_features_pdf,
    CAST(NULLIF(br_features_flash, '')        AS BOOLEAN)       AS br_features_flash,
    CAST(NULLIF(br_features_java, '')         AS BOOLEAN)       AS br_features_java,
    CAST(NULLIF(br_features_director, '')     AS BOOLEAN)       AS br_features_director,
    CAST(NULLIF(br_features_quicktime, '')    AS BOOLEAN)       AS br_features_quicktime,
    CAST(NULLIF(br_features_realplayer, '')   AS BOOLEAN)       AS br_features_realplayer,
    CAST(NULLIF(br_features_windowsmedia, '') AS BOOLEAN)       AS br_features_windowsmedia,
    CAST(NULLIF(br_features_gears, '')        AS BOOLEAN)       AS br_features_gears,
    CAST(NULLIF(br_features_silverlight, '')  AS BOOLEAN)       AS br_features_silverlight,
    CAST(NULLIF(br_cookies, '')               AS BOOLEAN)       AS br_cookies,
    NULLIF(br_colordepth, '')                                   AS br_colordepth,
    CAST(NULLIF(br_viewwidth, '')             AS INT)           AS br_viewwidth,
    CAST(NULLIF(br_viewheight, '')            AS INT)           AS br_viewheight,
    NULLIF(os_name, '')                                         AS os_name,
    NULLIF(os_family, '')                                       AS os_family,
    NULLIF(os_manufacturer, '')                                 AS os_manufacturer,
    NULLIF(os_timezone, '')                                     AS os_timezone,
    NULLIF(dvce_type, '')                                       AS dvce_type,
    CAST(NULLIF(dvce_ismobile, '')            AS BOOLEAN)       AS dvce_ismobile,
    CAST(NULLIF(dvce_screenwidth, '')         AS INT)           AS dvce_screenwidth,
    CAST(NULLIF(dvce_screenheight, '')        AS INT)           AS dvce_screenheight,
    NULLIF(doc_charset, '')                                     AS doc_charset,
    CAST(NULLIF(doc_width, '')                AS INT)           AS doc_width,
    CAST(NULLIF(doc_height, '')               AS INT)           AS doc_height,
    NULLIF(tr_currency, '')                                     AS tr_currency,
    CAST(NULLIF(tr_total_base, '')            AS DOUBLE)        AS tr_total_base,
    CAST(NULLIF(tr_tax_base, '')              AS DOUBLE)        AS tr_tax_base,
    CAST(NULLIF(tr_shipping_base, '')         AS DOUBLE)        AS tr_shipping_base,
    NULLIF(ti_currency, '')                                     AS ti_currency,
    CAST(NULLIF(ti_price_base, '')            AS DOUBLE)        AS ti_price_base,
    NULLIF(base_currency, '')                                   AS base_currency,
    NULLIF(geo_timezone, '')                                    AS geo_timezone,
    NULLIF(mkt_clickid, '')                                     AS mkt_clickid,
    NULLIF(mkt_network, '')                                     AS mkt_network,
    NULLIF(etl_tags, '')                                        AS etl_tags,
    CAST(NULLIF(dvce_sent_tstamp, '')         AS TIMESTAMP)     AS dvce_sent_tstamp,
    NULLIF(refr_domain_userid, '')                              AS refr_domain_userid,
    CAST(NULLIF(refr_dvce_tstamp, '')         AS TIMESTAMP)     AS refr_dvce_tstamp,
    NULLIF(derived_contexts, '')                                AS derived_contexts,
    NULLIF(domain_sessionid, '')                                AS domain_sessionid,
    CAST(NULLIF(derived_tstamp, '')           AS TIMESTAMP)     AS derived_tstamp,
    NULLIF(event_vendor, '')                                    AS event_vendor,
    NULLIF(event_name, '')                                      AS event_name,
    NULLIF(event_format, '')                                    AS event_format,
    NULLIF(event_version, '')                                   AS event_version,
    NULLIF(event_fingerprint, '')                               AS event_fingerprint,
    CAST(NULLIF(true_tstamp, '')              AS TIMESTAMP)     AS true_tstamp,
    CAST(current_timestamp() AS TIMESTAMP)                      AS load_tstamp
FROM embucket.public_snowplow_manifest_scratch.enriched_raw;

