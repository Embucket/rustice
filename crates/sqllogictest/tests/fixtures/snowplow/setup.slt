# snowplow_web_users_sessions_this_run
# Full-refresh CTAS (creates table with correct schema)
#   ← full-refresh/users/scratch/snowplow_web_users_sessions_this_run.sql
statement ok
CREATE TABLE embucket.public_snowplow_manifest_scratch.snowplow_web_users_sessions_this_run AS
select
  a.*,
  min(a.start_tstamp) over(partition by a.domain_userid) as user_start_tstamp,
  max(a.end_tstamp) over(partition by a.domain_userid) as user_end_tstamp
from embucket.public_snowplow_manifest_derived.snowplow_web_sessions a
where exists (select 1 from embucket.public_snowplow_manifest_scratch.snowplow_web_base_sessions_this_run b where a.domain_userid = b.user_identifier)
;

# Incremental load (populates with real-timestamp data)
#   ← incremental/users/scratch/snowplow_web_users_sessions_this_run.sql
statement ok
INSERT INTO embucket.public_snowplow_manifest_scratch.snowplow_web_users_sessions_this_run
select
  a.*,
  min(a.start_tstamp) over(partition by a.domain_userid) as user_start_tstamp,
  max(a.end_tstamp) over(partition by a.domain_userid) as user_end_tstamp
from embucket.public_snowplow_manifest_derived.snowplow_web_sessions a
where exists (select 1 from embucket.public_snowplow_manifest_scratch.snowplow_web_base_sessions_this_run b where a.domain_userid = b.user_identifier)
;

# snowplow_web_users_aggs
# Full-refresh CTAS (creates table with correct schema)
#   ← full-refresh/users/scratch/snowplow_web_users_aggs.sql
statement ok
CREATE TABLE embucket.public_snowplow_manifest_scratch.snowplow_web_users_aggs AS
select
  domain_userid,
  -- time
  user_start_tstamp as start_tstamp,
  user_end_tstamp as end_tstamp,
  -- first/last session. Max to resolve edge case with multiple sessions with the same start/end tstamp
  max(case when start_tstamp = user_start_tstamp then domain_sessionid end) as first_domain_sessionid,
  max(case when end_tstamp = user_end_tstamp then domain_sessionid end) as last_domain_sessionid,
  -- engagement
  sum(page_views) as page_views,
  count(distinct domain_sessionid) as sessions,
  sum(engaged_time_in_s) as engaged_time_in_s
from embucket.public_snowplow_manifest_scratch.snowplow_web_users_sessions_this_run
group by 1,2,3
;

