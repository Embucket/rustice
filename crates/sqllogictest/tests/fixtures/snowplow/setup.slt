# snowplow_web_base_new_event_limits
# Full-refresh CTAS (creates table with correct schema)
#   ← full-refresh/base/scratch/snowplow_web_base_new_event_limits.sql
statement ok
CREATE TABLE embucket.public_snowplow_manifest_scratch.snowplow_web_base_new_event_limits AS
      select 
        cast('2026-04-01' as timestamp)
     as lower_limit,
              least(
    dateadd(
        day,
        60,
        cast('2026-04-01' as timestamp)
        )
,
    convert_timezone('UTC', convert_timezone('UTC', current_timestamp()))::timestamp
) as upper_limit
;

# Incremental load (populates with real-timestamp data)
#   ← incremental/base/scratch/snowplow_web_base_new_event_limits.sql
statement ok
INSERT INTO embucket.public_snowplow_manifest_scratch.snowplow_web_base_new_event_limits
      select
    dateadd(
        hour,
        -6,
        cast('2026-04-29 23:59:47.620621' as timestamp)
        )
 as lower_limit,
        least(
    dateadd(
        day,
        60,
        cast('2026-04-29 23:59:47.620621' as timestamp)
        )
,
    convert_timezone('UTC', convert_timezone('UTC', current_timestamp()))::timestamp
) as upper_limit
;

# snowplow_web_base_sessions_lifecycle_manifest
# Full-refresh CTAS (creates table with correct schema)
#   ← full-refresh/base/manifest/snowplow_web_base_sessions_lifecycle_manifest.sql
statement ok
CREATE TABLE embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_base_sessions_lifecycle_manifest AS
        with new_events_session_ids_init as (
            select
                COALESCE(
                    e.domain_sessionid,NULL
                ) as session_identifier,
                max(
                    COALESCE(
                        e.domain_userid,NULL
                    )
                ) as user_identifier, -- Edge case 1: Arbitary selection to avoid window function like first_value.
                min(collector_tstamp) as start_tstamp,
                max(collector_tstamp) as end_tstamp
            from embucket.public_snowplow_manifest.events e
            where
                dvce_sent_tstamp <= 
    dateadd(
        day,
        3,
        dvce_created_tstamp
        )
 -- don't process data that's too late
                and collector_tstamp >= 
        cast('9999-01-01 00:00:00' as timestamp)
                and collector_tstamp <= 
        cast('9999-01-01 00:00:00' as timestamp)
                and true
                and True --don't reprocess sessions that have already been processed.
            group by 1
        ), new_events_session_ids as (
            select *
            from new_events_session_ids_init e
                where session_identifier is not null
                and not exists (select 1 from embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_base_quarantined_sessions as a where a.session_identifier = e.session_identifier) -- don't continue processing v.long sessions
        )
        , session_lifecycle as (
        select * from new_events_session_ids
        )
        select
        sl.session_identifier,
        sl.user_identifier,
        sl.start_tstamp,
        least(
    dateadd(
        day,
        3,
        sl.start_tstamp
        )
, sl.end_tstamp) as end_tstamp -- limit session length to max_session_days
        from session_lifecycle sl
;

# Incremental load (populates with real-timestamp data)
#   ← incremental/base/manifest/snowplow_web_base_sessions_lifecycle_manifest.sql
statement ok
INSERT INTO embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_base_sessions_lifecycle_manifest
        with new_events_session_ids_init as (
            select
                COALESCE(
                    e.domain_sessionid,NULL
                ) as session_identifier,
                max(
                    COALESCE(
                        e.domain_userid,NULL
                    )
                ) as user_identifier, -- Edge case 1: Arbitary selection to avoid window function like first_value.
                min(collector_tstamp) as start_tstamp,
                max(collector_tstamp) as end_tstamp
            from embucket.public_snowplow_manifest.events e
            where
                dvce_sent_tstamp <= 
    dateadd(
        day,
        3,
        dvce_created_tstamp
        )
 -- don't process data that's too late
                and collector_tstamp >= 
        cast('2026-04-01 00:00:00' as timestamp)
                and collector_tstamp <= 
        cast('2026-04-30 05:17:54' as timestamp)
                and true
                and True --don't reprocess sessions that have already been processed.
            group by 1
        ), new_events_session_ids as (
            select *
            from new_events_session_ids_init e
                where session_identifier is not null
                and not exists (select 1 from embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_base_quarantined_sessions as a where a.session_identifier = e.session_identifier) -- don't continue processing v.long sessions
        )
        , session_lifecycle as (
        select * from new_events_session_ids
        )
        select
        sl.session_identifier,
        sl.user_identifier,
        sl.start_tstamp,
        least(
    dateadd(
        day,
        3,
        sl.start_tstamp
        )
, sl.end_tstamp) as end_tstamp -- limit session length to max_session_days
        from session_lifecycle sl
;

# snowplow_web_base_sessions_this_run
# Full-refresh CTAS (creates table with correct schema)
#   ← full-refresh/base/scratch/snowplow_web_base_sessions_this_run.sql
statement ok
CREATE TABLE embucket.public_snowplow_manifest_scratch.snowplow_web_base_sessions_this_run AS
        select
        s.session_identifier,
        s.user_identifier,
        s.start_tstamp,
        -- end_tstamp used in next step to limit events. When backfilling, set end_tstamp to upper_limit if end_tstamp > upper_limit.
        -- This ensures we don't accidentally process events after upper_limit
        case when s.end_tstamp > 
        cast('9999-01-01 00:00:00' as timestamp)
     then 
        cast('9999-01-01 00:00:00' as timestamp)
     else s.end_tstamp end as end_tstamp
        from embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_base_sessions_lifecycle_manifest s
        where
        -- General window of start_tstamps to limit table scans. Logic complicated by backfills.
        -- To be within the run, session start_tstamp must be >= lower_limit - max_session_days as we limit end_tstamp in manifest to start_tstamp + max_session_days
        s.start_tstamp >= 
        cast('9999-01-01 00:00:00' as timestamp)
        and s.start_tstamp <= 
        cast('9999-01-01 00:00:00' as timestamp)
        -- Select sessions within window that either; start or finish between lower & upper limit, start and finish outside of lower and upper limits
        and not (s.start_tstamp > 
        cast('9999-01-01 00:00:00' as timestamp)
     or s.end_tstamp < 
        cast('9999-01-01 00:00:00' as timestamp)
    )
;

