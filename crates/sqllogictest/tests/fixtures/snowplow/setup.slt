        using embucket.public_snowplow_manifest_derived.snowplow_web_users__dbt_tmp as DBT_INTERNAL_SOURCE
        on (
            DBT_INTERNAL_DEST.start_tstamp between '2026-04-29 21:04:18.917662' and '2026-04-29 21:04:20.081686'
