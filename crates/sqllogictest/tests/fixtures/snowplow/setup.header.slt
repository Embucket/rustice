# Shared setup for the dbt_snowplow_web sqllogictest suite — static header.
#
# This file is concatenated by dev/regen-snowplow-setup.sh into the generated
# setup.slt; do not include it directly from leaf .slt files.
#
# It creates the schemas, declares the typed `events` table, loads it from
# the committed parquet fixture (events1.parquet), and stubs the three dim
# seeds. The parquet files are produced by the upstream
# snowplow-events-parquet pipeline (mirroring its sql/tsv_to_parquet.sql.tmpl
# transformation); the runtime CTAS that used to do NULLIF/CAST + regex
# extraction is gone. Everything else in the dbt-snowplow-web DAG is
# materialised by the generated tail of setup.slt.
#
# The `COPY INTO` below uses `${CRATE_ROOT}` to reach the committed parquet.
# The harness sets that variable via `Runner::set_var` to the crate's
# absolute manifest directory. Substitution is bracketed with `control
# substitution on/off` so the surrounding dbt-compiled SQL (which contains
# literal `$` references) is unaffected.

# ---------------------------------------------------------------------------
# Schemas
# ---------------------------------------------------------------------------

statement ok
CREATE SCHEMA IF NOT EXISTS embucket.public_snowplow_manifest;

statement ok
CREATE SCHEMA IF NOT EXISTS embucket.public_snowplow_manifest_scratch;

statement ok
CREATE SCHEMA IF NOT EXISTS embucket.public_snowplow_manifest_snowplow_manifest;

statement ok
CREATE SCHEMA IF NOT EXISTS embucket.public_snowplow_manifest_derived;

# ---------------------------------------------------------------------------
# Typed events table. Loaded directly from the pre-baked typed-TSV fixture
# (events1.csv); the CTAS that used to type-cast and regex-extract is now
# done offline by dev/regen-snowplow-csvs.sh and the result is committed
# as events1.csv / events2.csv. COPY INTO converts empty cells to NULL for
# all column types (including TIMESTAMP / INT) so empty cells in the TSV
# encode NULL with no extra NULLIF gymnastics.
# ---------------------------------------------------------------------------

statement ok
CREATE TABLE embucket.public_snowplow_manifest.events (
  app_id                                      VARCHAR,
  platform                                    VARCHAR,
  etl_tstamp                                  TIMESTAMP,
  collector_tstamp                            TIMESTAMP,
  dvce_created_tstamp                         TIMESTAMP,
  event                                       VARCHAR,
  event_id                                    VARCHAR,
  txn_id                                      INT,
  name_tracker                                VARCHAR,
  v_tracker                                   VARCHAR,
  v_collector                                 VARCHAR,
  v_etl                                       VARCHAR,
  user_id                                     VARCHAR,
  user_ipaddress                              VARCHAR,
  user_fingerprint                            VARCHAR,
  domain_userid                               VARCHAR,
  domain_sessionidx                           INT,
  network_userid                              VARCHAR,
  geo_country                                 VARCHAR,
  geo_region                                  VARCHAR,
  geo_city                                    VARCHAR,
  geo_zipcode                                 VARCHAR,
  geo_latitude                                DOUBLE,
  geo_longitude                               DOUBLE,
  geo_region_name                             VARCHAR,
  ip_isp                                      VARCHAR,
  ip_organization                             VARCHAR,
  ip_domain                                   VARCHAR,
  ip_netspeed                                 VARCHAR,
  page_url                                    VARCHAR,
  page_title                                  VARCHAR,
  page_referrer                               VARCHAR,
  page_urlscheme                              VARCHAR,
  page_urlhost                                VARCHAR,
  page_urlport                                INT,
  page_urlpath                                VARCHAR,
  page_urlquery                               VARCHAR,
  page_urlfragment                            VARCHAR,
  refr_urlscheme                              VARCHAR,
  refr_urlhost                                VARCHAR,
  refr_urlport                                INT,
  refr_urlpath                                VARCHAR,
  refr_urlquery                               VARCHAR,
  refr_urlfragment                            VARCHAR,
  refr_medium                                 VARCHAR,
  refr_source                                 VARCHAR,
  refr_term                                   VARCHAR,
  mkt_medium                                  VARCHAR,
  mkt_source                                  VARCHAR,
  mkt_term                                    VARCHAR,
  mkt_content                                 VARCHAR,
  mkt_campaign                                VARCHAR,
  contexts                                    VARCHAR,
  contexts_com_snowplowanalytics_snowplow_web_page_1 VARCHAR,
  se_category                                 VARCHAR,
  se_action                                   VARCHAR,
  se_label                                    VARCHAR,
  se_property                                 VARCHAR,
  se_value                                    DOUBLE,
  unstruct_event                              VARCHAR,
  tr_orderid                                  VARCHAR,
  tr_affiliation                              VARCHAR,
  tr_total                                    DOUBLE,
  tr_tax                                      DOUBLE,
  tr_shipping                                 DOUBLE,
  tr_city                                     VARCHAR,
  tr_state                                    VARCHAR,
  tr_country                                  VARCHAR,
  ti_orderid                                  VARCHAR,
  ti_sku                                      VARCHAR,
  ti_name                                     VARCHAR,
  ti_category                                 VARCHAR,
  ti_price                                    DOUBLE,
  ti_quantity                                 INT,
  pp_xoffset_min                              INT,
  pp_xoffset_max                              INT,
  pp_yoffset_min                              INT,
  pp_yoffset_max                              INT,
  useragent                                   VARCHAR,
  br_name                                     VARCHAR,
  br_family                                   VARCHAR,
  br_version                                  VARCHAR,
  br_type                                     VARCHAR,
  br_renderengine                             VARCHAR,
  br_lang                                     VARCHAR,
  br_features_pdf                             BOOLEAN,
  br_features_flash                           BOOLEAN,
  br_features_java                            BOOLEAN,
  br_features_director                        BOOLEAN,
  br_features_quicktime                       BOOLEAN,
  br_features_realplayer                      BOOLEAN,
  br_features_windowsmedia                    BOOLEAN,
  br_features_gears                           BOOLEAN,
  br_features_silverlight                     BOOLEAN,
  br_cookies                                  BOOLEAN,
  br_colordepth                               VARCHAR,
  br_viewwidth                                INT,
  br_viewheight                               INT,
  os_name                                     VARCHAR,
  os_family                                   VARCHAR,
  os_manufacturer                             VARCHAR,
  os_timezone                                 VARCHAR,
  dvce_type                                   VARCHAR,
  dvce_ismobile                               BOOLEAN,
  dvce_screenwidth                            INT,
  dvce_screenheight                           INT,
  doc_charset                                 VARCHAR,
  doc_width                                   INT,
  doc_height                                  INT,
  tr_currency                                 VARCHAR,
  tr_total_base                               DOUBLE,
  tr_tax_base                                 DOUBLE,
  tr_shipping_base                            DOUBLE,
  ti_currency                                 VARCHAR,
  ti_price_base                               DOUBLE,
  base_currency                               VARCHAR,
  geo_timezone                                VARCHAR,
  mkt_clickid                                 VARCHAR,
  mkt_network                                 VARCHAR,
  etl_tags                                    VARCHAR,
  dvce_sent_tstamp                            TIMESTAMP,
  refr_domain_userid                          VARCHAR,
  refr_dvce_tstamp                            TIMESTAMP,
  derived_contexts                            VARCHAR,
  domain_sessionid                            VARCHAR,
  derived_tstamp                              TIMESTAMP,
  event_vendor                                VARCHAR,
  event_name                                  VARCHAR,
  event_format                                VARCHAR,
  event_version                               VARCHAR,
  event_fingerprint                           VARCHAR,
  true_tstamp                                 TIMESTAMP,
  load_tstamp                                 TIMESTAMP
);

control substitution on

statement ok
COPY INTO embucket.public_snowplow_manifest.events
FROM 'file://${CRATE_ROOT}/tests/fixtures/snowplow/events1.parquet'
FILE_FORMAT = ( TYPE = 'PARQUET' );

control substitution off

# ---------------------------------------------------------------------------
# Dimension seeds shipped by dbt-snowplow-web. Columns match the headers of
# the package's seed CSVs (dbt_packages/snowplow_web/seeds/*.csv). Stubs are
# empty for now; populating them only affects output values, not planning.
# ---------------------------------------------------------------------------

statement ok
CREATE TABLE embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_dim_ga4_source_categories (
    source VARCHAR,
    source_category VARCHAR
);

statement ok
CREATE TABLE embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_dim_rfc_5646_language_mapping (
    lang_tag VARCHAR,
    name VARCHAR
);

statement ok
CREATE TABLE embucket.public_snowplow_manifest_snowplow_manifest.snowplow_web_dim_geo_country_mapping (
    name VARCHAR,
    alpha_2 VARCHAR,
    alpha_3 VARCHAR,
    country_code VARCHAR,
    iso_3166_2 VARCHAR,
    region VARCHAR,
    sub_region VARCHAR,
    intermediate_region VARCHAR,
    region_code VARCHAR,
    sub_region_code VARCHAR,
    intermediate_region_code VARCHAR
);
