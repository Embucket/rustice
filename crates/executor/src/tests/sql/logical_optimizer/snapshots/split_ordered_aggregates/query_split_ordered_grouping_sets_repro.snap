source: crates/executor/src/tests/sql/logical_optimizer/split_ordered_aggregates.rs
assertion_line: 14
description: "\"WITH src(page_url, device_class, lcp, fid) AS ( \\\n        SELECT '/u1', 'mobile', 120, 220 UNION ALL \\\n        SELECT '/u1', 'desktop', 110, 210 UNION ALL \\\n        SELECT '/u2', 'mobile', 130, 230 \\\n     ) \\\n     SELECT \\\n        page_url, \\\n        device_class, \\\n        GROUPING_ID(page_url, device_class) AS id_url_and_device, \\\n        PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY lcp) AS p_lcp, \\\n        PERCENTILE_CONT(0.5) WITHIN GROUP (ORDER BY fid) AS p_fid \\\n     FROM src \\\n     GROUP BY GROUPING SETS ((), (page_url, device_class), (device_class)) ORDER BY page_url, device_class\""
---
Err(
    "Error: DataFusion error: Error during planning: WITHIN GROUP is only supported for ordered-set aggregate functions",
)
